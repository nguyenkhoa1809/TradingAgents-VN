# MarketWire — mau file .env. Copy thanh .env va dien gia tri that.
# KHONG commit .env (da gitignore) — chi .env.example nay duoc track.

# LLM providers (bulk summarize + rerank — xem sources.yaml de doi provider)
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=          # chi can neu sources.yaml doi provider sang claude

# Telegram notify (ingest/notify.py)
TELEGRAM_BOT_TOKEN=         # lay tu @BotFather
TELEGRAM_CHAT_ID=           # dung @userinfobot de lay

# Cloudflare R2 — cho scripts/db_sync.py (local sync_local.bat + GitHub Actions secrets)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=              # tim trong Cloudflare dashboard > R2
R2_BUCKET_NAME=marketwire-data

# Cloudflare Pages deploy — CHI dung boi GitHub Actions (buoc Wrangler deploy),
# khong duoc doc boi script Python nao trong repo nay. Set trong GitHub
# Settings > Secrets > Actions, khong can dien o day khi chay local.
CLOUDFLARE_API_TOKEN=
